# ═══════════════════════════════════════════════════
# AI INTERVIEWER — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this to .env and fill in your API keys

# ── Groq (FREE — no credit card needed) ──
# Sign up at https://console.groq.com → Get API key
GROQ_API_KEY=gsk_your_key_here

# ── SarvamAI (₹1000 FREE credits on signup) ──
# Sign up at https://dashboard.sarvam.ai → Get API key
SARVAM_API_KEY=your_sarvam_key_here

# ── LiveKit (FREE tier available) ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Ollama (Local — no key needed) ──
# Just run: ollama pull llama3.2:3b && ollama serve
OLLAMA_BASE_URL=http://localhost:11434
