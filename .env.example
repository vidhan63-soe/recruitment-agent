# ============================================================
# Recruitment Agent — Production Environment Template
# Copy to .env and fill in real values before deploying
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- GPU Settings ---
# auto | cuda | cpu
DEVICE=auto

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# --- Sarvam AI ---
SARVAM_API_KEY=your_sarvam_api_key_here
LLM_PROVIDER=auto

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./vectorstore
CHROMA_COLLECTION_NAME=resumes

# --- Resume Processing ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_RESUME_SIZE_MB=10
SUPPORTED_FORMATS=.pdf,.docx

# --- Matching ---
TOP_K_CANDIDATES=10
MIN_MATCH_SCORE=0.35

# --- CORS (comma-separated allowed origins, or * for dev only) ---
# Production example: CORS_ORIGINS=https://your-frontend.com,https://www.your-frontend.com
CORS_ORIGINS=*

# --- Interview Agent URL (where the Next.js frontend is hosted) ---
# Production example: INTERVIEW_BASE_URL=https://your-frontend.com/candidate/interview
INTERVIEW_BASE_URL=http://localhost:3000/candidate/interview

# --- Email (Gmail SMTP) ---
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
